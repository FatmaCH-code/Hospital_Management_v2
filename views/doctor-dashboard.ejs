<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MediCore — Doctor Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Lora:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body class="dash-body">

  <aside class="sidebar">
    <div class="sb-logo">
      <div class="sb-cross">✚</div>
      <div class="sb-logo-text">MediCore</div>
    </div>
    <nav class="sb-nav">
      <a href="#overview"     class="sb-link active" title="Overview"><i class="bi bi-speedometer2"></i></a>
      <a href="#today"        class="sb-link" title="Today's Schedule"><i class="bi bi-calendar-day-fill"></i></a>
      <a href="#appointments" class="sb-link" title="All Appointments"><i class="bi bi-calendar2-check-fill"></i></a>
      <a href="#patients"     class="sb-link" title="My Patients"><i class="bi bi-people-fill"></i></a>
      <a href="#treatment"    class="sb-link" title="Add Treatment"><i class="bi bi-plus-square-fill"></i></a>
    </nav>
    <div class="sb-bottom">
      <div class="sb-avatar sb-avatar-sage" title="<%= user.name %>"><%= user.data.first_name ? user.data.first_name.charAt(0) : 'D' %></div>
      <a href="/logout" class="sb-link sb-logout" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </aside>

  <main class="dash-main">

    <!-- TOP SEARCH BAR -->
    <div class="top-bar">
      <div class="search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" class="search-input" id="globalSearch" placeholder="Search patients or appointments..." autocomplete="off"/>
      </div>
      <button class="search-filter-btn" onclick="document.getElementById('today').scrollIntoView({behavior:'smooth'})">
        <i class="bi bi-calendar-day-fill"></i> Today
      </button>
      <button class="search-filter-btn" onclick="document.getElementById('patients').scrollIntoView({behavior:'smooth'})">
        <i class="bi bi-people-fill"></i> Patients
      </button>
      <div class="top-bar-date">
        <i class="bi bi-calendar3"></i>
        <%= new Date().toLocaleDateString('en-US', {weekday:'short', month:'short', day:'numeric'}) %>
      </div>
    </div>

    <header class="dash-header">
      <div>
        <h1 class="dash-title"><span class="highlight-text"><%= user.name %></span></h1>
        <p class="dash-sub"><span class="spec-badge"><%= user.data.specialization %></span> &nbsp;·&nbsp; <%= user.data.hospital_branch %></p>
      </div>
      <div class="header-right">
        <div class="exp-chip"><i class="bi bi-award-fill"></i> <%= user.data.years_experience %> yrs exp.</div>
      </div>
    </header>

    <% if (success) { %><div class="flash flash-ok"><i class="bi bi-check-circle-fill"></i> <%= success %></div><% } %>
    <% if (error)   { %><div class="flash flash-err"><i class="bi bi-x-circle-fill"></i> <%= error %></div><% } %>

    <!-- STATS -->
    <section id="overview" class="stats-row">
      <div class="kpi-card kpi-amber">
        <div class="kpi-icon"><i class="bi bi-calendar-day"></i></div>
        <div class="kpi-val"><%= stats.today || 0 %></div>
        <div class="kpi-label">Today</div>
      </div>
      <div class="kpi-card kpi-sky">
        <div class="kpi-icon"><i class="bi bi-hourglass-split"></i></div>
        <div class="kpi-val"><%= stats.scheduled || 0 %></div>
        <div class="kpi-label">Scheduled</div>
      </div>
      <div class="kpi-card kpi-sage">
        <div class="kpi-icon"><i class="bi bi-check2-circle"></i></div>
        <div class="kpi-val"><%= stats.completed || 0 %></div>
        <div class="kpi-label">Completed</div>
      </div>
      <div class="kpi-card kpi-teal">
        <div class="kpi-icon"><i class="bi bi-people-fill"></i></div>
        <div class="kpi-val"><%= myPatients.length %></div>
        <div class="kpi-label">My Patients</div>
      </div>
    </section>

    <!-- TODAY -->
    <section id="today" class="content-block">
      <div class="block-header">
        <h2 class="block-title"><span class="title-dot dot-amber"></span>Today's Schedule</h2>
        <span class="count-tag"><%= todayAppts.length %> appointments</span>
      </div>
      <% if (todayAppts.length === 0) { %>
        <div class="empty-box"><i class="bi bi-sun"></i><p>No appointments today — enjoy your day!</p></div>
      <% } else { %>
      <div class="timeline">
        <% todayAppts.forEach((a, i) => { %>
        <div class="timeline-item">
          <div class="tl-time"><%= a.appointment_time ? a.appointment_time.slice(0,5) : '--:--' %></div>
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-name"><%= a.pat_first %> <%= a.pat_last %> <span class="tl-gender"><%= a.gender %></span></div>
            <div class="tl-detail"><i class="bi bi-hash"></i> ID: <strong><%= a.appointment_id %></strong></div>
            <div class="tl-detail"><i class="bi bi-chat-text"></i> <%= a.reason_for_visit %></div>
            <div class="tl-detail"><i class="bi bi-telephone"></i> <%= a.contact_number %></div>
            <div class="tl-actions">
              <span class="status-pill sp-<%= a.status.toLowerCase().replace(' ','_') %>"><%= a.status %></span>
              <form action="/doctor/update-appointment" method="POST" style="display:inline">
                <input type="hidden" name="appointment_id" value="<%= a.appointment_id %>"/>
                <select name="status" class="mini-select" onchange="this.form.submit()">
                  <option value="">Update →</option>
                  <option value="Scheduled">Scheduled</option>
                  <option value="Completed">Completed</option>
                  <option value="Cancelled">Cancelled</option>
                </select>
              </form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </section>

    <!-- ALL APPOINTMENTS -->
    <section id="appointments" class="content-block">
      <div class="block-header">
        <h2 class="block-title"><span class="title-dot dot-sky"></span>All Appointments</h2>
        <div class="block-search">
          <i class="bi bi-search"></i>
          <input type="text" placeholder="Search appointments..." oninput="filterTable(this,'appt-table')"/>
        </div>
        <span class="count-tag"><%= allAppts.length %></span>
      </div>
      <div class="table-wrap">
        <table class="nice-table" id="appt-table">
          <thead><tr><th>Patient</th><th>Date</th><th>Time</th><th>Reason</th><th>Status</th><th>Action</th></tr></thead>
          <tbody>
            <% allAppts.forEach(a => { %>
            <tr>
              <td><strong><%= a.pat_first %> <%= a.pat_last %></strong></td>
              <td class="date-cell"><%= new Date(a.appointment_date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></td>
              <td><%= a.appointment_time ? a.appointment_time.slice(0,5) : '—' %></td>
              <td class="reason-cell"><%= a.reason_for_visit %></td>
              <td><span class="status-pill sp-<%= a.status.toLowerCase().replace(' ','_') %>"><%= a.status %></span></td>
              <td>
                <form action="/doctor/update-appointment" method="POST">
                  <input type="hidden" name="appointment_id" value="<%= a.appointment_id %>"/>
                  <select name="status" class="mini-select" onchange="this.form.submit()">
                    <option>Change</option>
                    <option value="Scheduled">Scheduled</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                  </select>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- PATIENTS GRID -->
    <section id="patients" class="content-block">
      <div class="block-header">
        <h2 class="block-title"><span class="title-dot dot-teal"></span>My Patients</h2>
        <div class="block-search">
          <i class="bi bi-search"></i>
          <input type="text" id="patSearch" placeholder="Search patients..."/>
        </div>
        <span class="count-tag"><%= myPatients.length %></span>
      </div>
      <% if (myPatients.length === 0) { %>
        <div class="empty-box"><i class="bi bi-person-x"></i><p>No patients yet</p></div>
      <% } else { %>
      <div class="patient-mosaic" id="patient-mosaic">
        <% myPatients.forEach(p => { %>
        <div class="p-tile" data-name="<%= p.first_name %> <%= p.last_name %>">
          <div class="p-tile-av"><%= p.first_name.charAt(0) %><%= p.last_name.charAt(0) %></div>
          <div class="p-tile-name"><%= p.first_name %> <%= p.last_name %></div>
          <div class="p-tile-info"><i class="bi bi-gender-ambiguous"></i> <%= p.gender %></div>
          <div class="p-tile-info"><i class="bi bi-telephone"></i> <%= p.contact_number %></div>
          <div class="p-tile-ins"><i class="bi bi-shield-check"></i> <%= p.insurance_provider || 'Uninsured' %></div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </section>

    <!-- ADD TREATMENT -->
    <section id="treatment" class="content-block">
      <div class="block-header">
        <h2 class="block-title"><span class="title-dot dot-sage"></span>Add Treatment</h2>
      </div>
      <div class="form-panel">
        <form action="/doctor/add-treatment" method="POST">
          <div class="form-trio">
            <div class="form-item">
              <label class="flabel">Appointment</label>
              <select name="appointment_id" class="finput" required>
                <option value="">— Select Appointment —</option>
                <% allAppts.forEach(a => { %>
                <option value="<%= a.appointment_id %>">
                  <%= a.appointment_id %> · <%= a.pat_first %> <%= a.pat_last %> · <%= a.appointment_date ? new Date(a.appointment_date).toLocaleDateString() : '' %>
                </option>
                <% }) %>
              </select>
            </div>
            <div class="form-item">
              <label class="flabel">Treatment Type</label>
              <select name="treatment_type" class="finput" required>
                <option value="">— Select —</option>
                <option>Consultation</option><option>Surgery</option>
                <option>Physical Therapy</option><option>Medication</option>
                <option>Diagnostic Test</option><option>Vaccination</option>
                <option>Emergency Care</option><option>Other</option>
              </select>
            </div>
            <div class="form-item">
              <label class="flabel">Cost ($)</label>
              <input type="number" step="0.01" name="cost" class="finput" placeholder="0.00" required/>
            </div>
          </div>
          <div class="form-item" style="margin-top:1rem">
            <label class="flabel">Notes / Description</label>
            <textarea name="description" class="finput" rows="3" placeholder="Treatment details, prescriptions..."></textarea>
          </div>
          <button type="submit" class="fbtn fbtn-sage" style="margin-top:1rem">
            <i class="bi bi-plus-circle"></i> Add Treatment
          </button>
        </form>
      </div>
    </section>

  </main>

  <script>
    function filterTable(input, tableId) {
      const q = input.value.toLowerCase();
      document.getElementById(tableId).querySelectorAll('tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }

    // Patient tile search
    document.getElementById('patSearch') && document.getElementById('patSearch').addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('#patient-mosaic .p-tile').forEach(tile => {
        tile.style.display = tile.dataset.name.toLowerCase().includes(q) ? '' : 'none';
      });
    });

    // Global search
    document.getElementById('globalSearch').addEventListener('input', function() {
      const q = this.value.toLowerCase().trim();
      if (!q) {
        document.querySelectorAll('#appt-table tbody tr').forEach(r => r.style.display = '');
        document.querySelectorAll('#patient-mosaic .p-tile').forEach(t => t.style.display = '');
        return;
      }
      document.getElementById('appt-table').querySelectorAll('tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
      document.querySelectorAll('#patient-mosaic .p-tile').forEach(tile => {
        tile.style.display = tile.dataset.name.toLowerCase().includes(q) ? '' : 'none';
      });
    });

    // Sidebar tooltips
    document.querySelectorAll('.sb-link[title]').forEach(el => {
      el.addEventListener('mouseenter', function() {
        const tip = document.createElement('div');
        tip.className = 'sb-tooltip';
        tip.textContent = this.getAttribute('title');
        document.body.appendChild(tip);
        const r = this.getBoundingClientRect();
        tip.style.top = (r.top + r.height/2 - tip.offsetHeight/2) + 'px';
        tip.style.left = (r.right + 10) + 'px';
        this._tip = tip;
      });
      el.addEventListener('mouseleave', function() { if(this._tip) this._tip.remove(); });
    });

    // Active nav
    const secs = document.querySelectorAll('section[id]');
    const links = document.querySelectorAll('.sb-link[href^="#"]');
    window.addEventListener('scroll', () => {
      let cur = '';
      secs.forEach(s => { if (window.scrollY >= s.offsetTop - 120) cur = s.id; });
      links.forEach(l => {
        l.classList.remove('active');
        if (l.getAttribute('href') === '#' + cur) l.classList.add('active');
      });
    });
  </script>
</body>
</html>
